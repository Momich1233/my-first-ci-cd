# 1. Базовый образ с уже установленным Python
FROM python:3.11-slim

# 2. Указываем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Копируем файл зависимостей отдельно (для кэширования слоев)
COPY requirements.txt .

# 4. Устанавливаем библиотеки
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем остальной код проекта в контейнер
COPY . .

# 6. Команда, которая выполнится при старте контейнера
CMD ["python", "main.py"]